
h=int(input("Digite um número  "))
l=int(input("Digite outro número  "))

total = h+l
total2 = h-l
total3 = h*l
total4 = h/l

pergunta=str(input("Qual operação você deseja realizar? Digite: soma, subtração, multiplicação ou divisão  "))
if pergunta == "soma":
    print(total)
elif pergunta == "subtração":
    print(total2)
